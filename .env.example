# Servidor
PORT=3000
NODE_ENV=development

# Orígenes del front (CORS), separados por coma. Debe coincidir con la URL del navegador (esquema + host + puerto).
# Ejemplo: http://localhost:3000,https://tu-dominio.com
CORS_ORIGIN=http://localhost:3000

# MongoDB (URI completa; por defecto en código: mongodb://127.0.0.1:27017/cms-api)
MONGODB_URI=mongodb://127.0.0.1:27017/cms-api

# JWT (el código usa un secreto de desarrollo si falta JWT_SECRET)
JWT_SECRET=change-me-in-production
# Duración del token en segundos (604800 = 7 días)
JWT_EXPIRES_SEC=604800
